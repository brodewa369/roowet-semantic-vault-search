# ── Required ────────────────────────────────────────────────────────────────

# Path ke Obsidian vault / markdown folder yang mau di-index
VAULT_ROOT=./vault

# Path ke LanceDB vector store (auto-created kalau belum ada)
LANCEDB_PATH=./data/lancedb

# Ollama API endpoint (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Embedding model — tested: bge-m3 (1024d), nomic-embed-text (768d)
EMBED_MODEL=bge-m3

# Embedding dimension — 1024 for bge-m3, 768 for nomic-embed-text
EMBED_DIM=1024


# ── Optional (have sensible defaults) ──────────────────────────────────────

# Chunk size in characters (default: 512)
CHUNK_SIZE=512

# Chunk overlap in characters (default: 64)
OVERLAP=64

# Batch size for embedding API calls (default: 50)
BATCH_SIZE=50

# Directories to exclude from indexing (comma-separated)
EXCLUDE_DIRS=.obsidian,.trash,.git,__pycache__,node_modules

# Max backups to keep (default: 2)
MAX_BACKUPS=2

# File watcher interval in seconds (default: 5)
WATCH_INTERVAL=5
